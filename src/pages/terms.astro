---
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<Base title="Terms"><Fragment slot="header"><Header /></Fragment>

  <section class="pt-28 pb-16 bg-grid" style="background:linear-gradient(135deg,#eef2ff 0%,#ffffff 35%,#faf5ff 100%)">
    <div class="max-w-6xl mx-auto px-6 lg:px-8"><div class="max-w-2xl"><p class="sl">Legal</p><h1 class="text-4xl sm:text-5xl font-heading font-bold text-gray-900 leading-tight mb-4">Terms &amp; conditions</h1><p class="text-sm text-gray-400">Last updated: 20 June 2026</p></div></div>
  </section>

  <section class="py-16 border-t border-gray-100">
    <div class="max-w-2xl mx-auto px-6 lg:px-8">
      <div class="prose space-y-6">
        <div><h2>1. Introduction</h2><p>These terms govern your use of protomonlabs.org. By using this website, you agree to these terms.</p></div>
        <div><h2>2. Intellectual Property</h2><p>All content is the property of Protomon Labs unless otherwise stated. Open-source code is licensed as indicated in repositories.</p></div>
        <div><h2>3. Analytics</h2><p>We use privacy-preserving, cookie-free analytics. No personal data is sold or shared.</p></div>
        <div><h2>4. Disclaimer</h2><p>Content is provided for informational purposes only. No warranties are made about completeness or accuracy.</p></div>
        <div><h2>5. Governing Law</h2><p>These terms are governed by the laws of England and Wales.</p></div>
        <div><h2>6. Contact</h2><p>hello@protomonlabs.org</p></div>
      </div>
    </div>
  </section>

<Fragment slot="footer"><Footer /></Fragment></Base>