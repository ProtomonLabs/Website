---
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import RF from "../components/ResearchFocus.astro";
---
<Base title="Home"><Fragment slot="header"><Header /></Fragment>
  <section class="relative overflow-hidden min-h-screen flex flex-col justify-center pt-20 hero-bg">
    <div class="absolute inset-0 bg-subtle-grid pointer-events-none hero-grid" />
    <div class="absolute inset-0 pointer-events-none dot-layer">
      <div class="dot" style="--x:15%;--y:20%;--d:12s;--del:0s;--s:18px" />
      <div class="dot" style="--x:70%;--y:35%;--d:14s;--del:2s;--s:14px" />
      <div class="dot" style="--x:85%;--y:65%;--d:10s;--del:4s;--s:22px" />
      <div class="dot" style="--x:25%;--y:75%;--d:16s;--del:1s;--s:12px" />
      <div class="dot" style="--x:50%;--y:15%;--d:13s;--del:3s;--s:16px" />
      <div class="dot" style="--x:60%;--y:85%;--d:11s;--del:5s;--s:13px" />
      <div class="dot" style="--x:90%;--y:25%;--d:15s;--del:6s;--s:20px" />
      <div class="dot" style="--x:10%;--y:55%;--d:18s;--del:7s;--s:15px" />
      <div class="dot" style="--x:40%;--y:45%;--d:9s;--del:3.5s;--s:11px" />
      <div class="dot" style="--x:75%;--y:10%;--d:17s;--del:0.5s;--s:24px" />
    </div>
    <div class="max-w-5xl mx-auto px-6 lg:px-8 py-8 md:py-12 flex-1 flex items-center">
      <div class="text-center max-w-4xl mx-auto w-full">
        <p class="sl justify-center animate-up mb-0">Genomics Infrastructure Lab</p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-heading font-bold leading-[0.85] tracking-tight mb-6 animate-up animate-up-d1 gradient-text">
          Infrastructure<br />
          for the<br />
          genome
        </h1>
        <p class="text-base md:text-lg text-stone-600 max-w-2xl mx-auto leading-relaxed mb-8 animate-up animate-up-d2">Protomon Labs builds open-source genomic infrastructure — maintained, documented, and production-ready.</p>
        <div class="flex gap-3 justify-center animate-up animate-up-d3"><a href="/about" class="btn-p">About the lab</a><a href="/contact" class="btn-s">Get in touch</a></div>
      </div>
    </div>
  </section>
  <div class="divider-gradient max-w-3xl mx-auto" />
  <RF />
  <div class="divider-gradient max-w-3xl mx-auto" />
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <p class="sl mb-4">The opportunity</p>
        <p class="text-2xl sm:text-3xl font-heading font-semibold text-stone-900 leading-snug">Genomic research produces extraordinary tools. The next step is making them sustainable — maintained, documented, and interoperable over the long term.</p>
      </div>
    </div>
  </section>
  <section class="py-20 bg-stone-50 border-y border-stone-100">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="max-w-xl mb-12">
        <p class="sl mb-0">Approach</p>
        <h2 class="text-3xl sm:text-4xl font-heading font-bold text-stone-900">What we do</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        <div class="card">
          <div class="icon-ring"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/></svg></div>
          <h3 class="font-heading font-semibold text-stone-900 mb-2">Open by default</h3>
          <p class="text-sm text-stone-600 leading-relaxed">AGPL licensing keeps our work in the commons. We also provide dual-licensing for organisations that need a commercial path.</p>
        </div>
        <div class="card">
          <div class="icon-ring"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></div>
          <h3 class="font-heading font-semibold text-stone-900 mb-2">Built for production</h3>
          <p class="text-sm text-stone-600 leading-relaxed">Versioned, tested, documented, and maintained. Software you can deploy with confidence.</p>
        </div>
        <div class="card">
          <div class="icon-ring"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>
          <h3 class="font-heading font-semibold text-stone-900 mb-2">Standards in practice</h3>
          <p class="text-sm text-stone-600 leading-relaxed">We turn specification documents into tested, deployable reference implementations for community standards.</p>
        </div>
      </div>
    </div>
  </section>
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 text-center">
      <div class="max-w-xl mx-auto">
        <p class="sl justify-center mb-0">Open Source</p>
        <h2 class="text-3xl font-heading font-bold text-stone-900 mb-3">Built in the open</h2>
        <p class="text-stone-600 leading-relaxed mb-6">All our tools are available on GitHub under AGPL. Community contributions and dual-licensing enquiries welcome.</p>
        <a href="/open-source" class="btn-p">Licensing &amp; repos →</a>
      </div>
    </div>
  </section>
  <section class="relative py-20 overflow-hidden" style="background:linear-gradient(135deg,#5b21b6,#4c1d95,#3b0764)">
    <div class="absolute inset-0 bg-subtle-grid opacity-[0.08]" />
    <div class="max-w-6xl mx-auto px-6 lg:px-8 text-center relative">
      <div class="max-w-xl mx-auto">
        <h2 class="text-3xl font-heading font-bold text-white mb-3">Building the foundations of genomic discovery</h2>
        <p class="text-cobalt-200 leading-relaxed mb-8">We partner with sequencing centers, biobanks, and tool developers working at genomic scale.</p>
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-3 bg-white hover:bg-stone-50 text-stone-800 font-medium rounded-xl transition-all active:scale-[0.97]">Get in touch →</a>
      </div>
    </div>
  </section>
<Fragment slot="footer"><Footer /></Fragment></Base>
<style>
  .hero-bg {
    background: linear-gradient(135deg, #fafaf9 0%, #ffffff 25%, #f5f3ff 50%, #ede9fe 75%, #fafaf9 100%);
    background-size: 400% 400%;
    animation: gradient-shimmer 15s ease-in-out infinite;
  }
  .hero-grid {
    animation: grid-drift 20s linear infinite;
  }
  @keyframes grid-drift {
    from { background-position: 0 0; }
    to { background-position: 48px 48px; }
  }
  .dot-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .dot {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--s);
    height: var(--s);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(109,40,217,0.55) 0%, rgba(109,40,217,0.15) 50%, transparent 100%);
    animation: dot-drift var(--d) ease-in-out var(--del) infinite alternate;
    filter: blur(1px);
  }
  @keyframes dot-drift {
    0%   { transform: translate(0, 0) scale(1); opacity: 0.3; }
    25%  { transform: translate(50px, -40px) scale(1.4); opacity: 0.8; }
    50%  { transform: translate(-40px, 60px) scale(0.7); opacity: 0.5; }
    75%  { transform: translate(30px, -50px) scale(1.2); opacity: 0.9; }
    100% { transform: translate(-40px, 20px) scale(0.8); opacity: 0.4; }
  }
</style>