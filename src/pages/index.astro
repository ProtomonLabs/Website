---
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import RF from "../components/ResearchFocus.astro";
import BC from "../components/BlogCard.astro";
---
<Base title="Home"><Fragment slot="header"><Header /></Fragment>
  <section class="relative overflow-hidden pt-20 pb-12" style="background:linear-gradient(135deg,#fafaf9 0%,#ffffff 30%,#ede9fe 100%)">
    <div class="absolute inset-0 bg-subtle-grid pointer-events-none" />
    <div class="gradient-orb -top-32 -left-32" />
    <div class="gradient-orb-lg bottom-0 -right-48" />
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <p class="sl justify-center animate-up">Genomics Infrastructure Lab</p>
        <h1 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-heading font-bold leading-[0.85] tracking-tight mb-6 animate-up animate-up-d1 gradient-text">
          Infrastructure<br />
          for the<br />
          genome
        </h1>
        <p class="text-lg md:text-xl text-stone-600 max-w-2xl mx-auto leading-relaxed mb-8 animate-up animate-up-d2">Protomon Labs builds the platforms, standards, and tools that underpin genomic discovery at scale.</p>
        <div class="flex gap-4 justify-center animate-up animate-up-d3"><a href="/projects" class="btn-p">Explore our work</a><a href="/about" class="btn-s">About the lab</a></div>
      </div>
    </div>
  </section>
  <div class="divider-gradient max-w-3xl mx-auto" />
  <RF />
  <div class="divider-gradient max-w-3xl mx-auto" />
  <section class="py-32 reveal">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-16 reveal reveal-d1"><p class="sl justify-center">Journal</p><h2 class="text-4xl sm:text-5xl font-heading font-bold text-stone-900">Latest writing</h2></div>
      <BC posts={[{title:"Building a Variant Annotation Infrastructure",description:"A practical guide to designing scalable, reproducible variant annotation infrastructure for production-grade genomic analysis.",pubDate:new Date("2026-06-15"),tags:["tutorial","infrastructure","annotation"],slug:"variant-annotation-pipelines"},{title:"Infrastructure Approaches to Non-coding GWAS",description:"How platform thinking is transforming fine-mapping of non-coding GWAS signals through integrated data layers.",pubDate:new Date("2026-06-10"),tags:["GWAS","infrastructure","non-coding"],slug:"non-coding-gwas-loci"}]} />
      <div class="mt-10 text-center"><a href="/blog" class="btn-p">Read the journal →</a></div>
    </div>
  </section>
  <section class="relative py-32 overflow-hidden" style="background:linear-gradient(135deg,#5b21b6,#4c1d95,#3b0764)">
    <div class="absolute inset-0 bg-subtle-grid opacity-[0.08]" />
    <div class="gradient-orb-lg -top-64 -left-64 opacity-40" />
    <div class="max-w-6xl mx-auto px-6 lg:px-8 text-center relative">
      <div class="max-w-xl mx-auto reveal">
        <h2 class="text-4xl font-heading font-bold text-white mb-4">Building the foundations of genomic discovery</h2>
        <p class="text-cobalt-200 leading-relaxed mb-10">We partner with sequencing centers, biobanks, and tool developers working at genomic scale.</p>
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-3 bg-white hover:bg-stone-50 text-cobalt-800 font-medium rounded-xl transition-all active:scale-[0.97]">Get in touch →</a>
      </div>
    </div>
  </section>
<Fragment slot="footer"><Footer /></Fragment></Base>