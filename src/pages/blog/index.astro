---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sorted = posts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .map((post) => ({
    title: post.data.title, description: post.data.description,
    pubDate: post.data.pubDate, tags: post.data.tags, slug: post.slug,
  }));
---

<BaseLayout title="Blog">
  <Fragment slot="header"><Header /></Fragment>

  <section class="pt-32 pb-16" style="background: linear-gradient(180deg, #fafaf9, #ffffff);">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="max-w-3xl">
        <span class="section-label">Journal</span>
        <h1 class="text-5xl md:text-6xl font-heading font-bold text-stone-900 leading-tight mb-6">The <span class="text-cobalt-600">journal</span></h1>
        <p class="text-lg text-stone-600 max-w-xl">Methodology notes, paper commentaries, and deep dives into variant analysis, statistical genetics, and computational genomics.</p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      {sorted.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {sorted.map((post) => (
            <a href={`/blog/${post.slug}`} class="card p-7 group block">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.tags.map((tag) => (<span class="tag text-[11px]">{tag}</span>))}
              </div>
              <h3 class="text-lg font-semibold text-stone-900 group-hover:text-cobalt-600 transition-colors mb-3 leading-snug">{post.title}</h3>
              <p class="text-stone-600 text-sm leading-relaxed mb-4 line-clamp-2">{post.description}</p>
              <div class="flex items-center justify-between">
                <time class="text-stone-400 text-xs">{post.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time>
                <span class="text-cobalt-500 text-xs font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">Read <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg></span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20"><p class="text-stone-400 text-lg">No posts yet. Check back soon.</p></div>
      )}
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>