---
import Base from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BC from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";
const posts = await getCollection("blog");
const s = posts.sort((a,b)=>b.data.pubDate.getTime()-a.data.pubDate.getTime()).map((p)=>({title:p.data.title,description:p.data.description,pubDate:p.data.pubDate,tags:p.data.tags,slug:p.slug}));
---
<Base title="Blog"><Fragment slot="header"><Header /></Fragment>
  <section class="relative pt-28 pb-16 overflow-hidden bg-subtle-grid" style="background:linear-gradient(135deg,#fafaf9 0%,#ffffff 30%,#ede9fe 100%)">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 relative">
      <div class="max-w-2xl"><p class="sl">Journal</p><h1 class="text-4xl sm:text-5xl font-heading font-bold text-stone-900 leading-tight mb-5">The journal</h1><p class="text-lg text-stone-600 max-w-xl">Notes on infrastructure, tooling, and methodology for genomic discovery at scale.</p></div>
    </div>
  </section>
  <section class="py-20 bg-stone-50 border-y border-stone-100 reveal">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      {s.length > 0 ? <BC posts={s} /> : (<p class="text-center text-stone-400 py-10">No posts yet.</p>)}
    </div>
  </section>
<Fragment slot="footer"><Footer /></Fragment></Base>