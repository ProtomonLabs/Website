---
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { icons } from "../data/icons";
const principles = [
  {
    title: "Open by default",
    body: "We build in the open because shared infrastructure is stronger. Every tool is publicly available under AGPL. We welcome community contributions because the best ideas can come from anywhere.",
    icon: "beaker",
    image: "/holding-plants.svg",
  },
  {
    title: "Built to last",
    body: "We apply professional software engineering practices to every tool the community depends on. Versioned, tested, documented, and maintained. Infrastructure that stays reliable beyond any single grant cycle or publication timeline.",
    icon: "code",
    image: "/cementing.svg",
  },
  {
    title: "Community first",
    body: "We contribute everything back upstream. When organisations build on our infrastructure, their enhancements flow back to the commons. We build with our users, not for them.",
    icon: "users",
    image: "/helping-up-ladder.svg",
  },
  {
    title: "Pragmatic progress",
    body: "We balance principles with practice. Open source ideals guide us, but what matters most is shipping infrastructure that works. We focus on outcomes over ideology.",
    icon: "layers",
    image: "/studying-implements.svg",
  },
];
---
<Base title="Principles"><Fragment slot="header"><Header /></Fragment>

  <section class="relative pt-28 pb-16 overflow-hidden bg-subtle-grid" style="background:linear-gradient(135deg,#fafaf9 0%,#ffffff 30%,#ede9fe 100%)">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 relative">
      <div class="max-w-2xl"><p class="sl">Values</p><h1 class="text-4xl sm:text-5xl font-heading font-bold text-stone-900 leading-tight mb-5">Our principles</h1><p class="text-lg md:text-xl text-stone-600 max-w-xl">The foundational beliefs that guide how we build, share, and collaborate.</p></div>
    </div>
  </section>

  {principles.map((p, i) => (
    <section class="py-16 bg-stone-50 border-y border-stone-100 reveal">
      <div class="max-w-6xl mx-auto px-6 lg:px-8">
        <div class={`grid md:grid-cols-2 gap-12 items-center ${i % 2 === 0 ? "" : "md:grid-flow-dense"}`}>
          <div class={i % 2 === 0 ? "" : "md:col-start-2"}>
            <div class="icon-ring mb-4" set:html={icons[p.icon]} />
            <h2 class="text-3xl font-heading font-bold text-stone-900 mb-4">{p.title}</h2>
            <p class="text-stone-600 leading-relaxed text-[17px]">{p.body}</p>
          </div>
          <div class={`flex items-center justify-center aspect-[4/3] p-6 ${i % 2 === 0 ? "" : "md:col-start-1 md:row-start-1"}`}>
            <img src={p.image} alt="" class="w-full h-full object-contain" />
          </div>
        </div>
      </div>
    </section>
  ))}

  <section class="relative py-16 overflow-hidden" style="background:linear-gradient(135deg,#5b21b6,#4c1d95,#3b0764)">
    <div class="absolute inset-0 bg-subtle-grid opacity-[0.08]" />
    <div class="max-w-6xl mx-auto px-6 lg:px-8 text-center relative">
      <div class="max-w-xl mx-auto">
        <h2 class="text-3xl font-heading font-bold text-white mb-3">Principles in practice</h2>
        <p class="text-cobalt-200 leading-relaxed mb-8">Every tool we build is shaped by these principles. See them in action across our repositories.</p>
        <a href="/open-source" class="inline-flex items-center gap-2 px-8 py-3 bg-white hover:bg-stone-50 text-stone-800 font-medium rounded-xl transition-all active:scale-[0.97]">Explore open source →</a>
      </div>
    </div>
  </section>

<Fragment slot="footer"><Footer /></Fragment></Base>