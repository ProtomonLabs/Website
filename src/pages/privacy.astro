---
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<Base title="Privacy"><Fragment slot="header"><Header /></Fragment>

  <section class="pt-28 pb-16" style="background:linear-gradient(135deg,#f8faff 0%,#ffffff 50%,#f5f3ff 100%)">
    <div class="max-w-6xl mx-auto px-6 lg:px-8"><div class="max-w-2xl"><p class="sl">Legal</p><h1 class="text-4xl sm:text-5xl font-heading font-bold text-gray-900 leading-tight mb-4">Privacy policy</h1><p class="text-sm text-gray-400">Last updated: 20 June 2026</p></div></div>
  </section>

  <section class="py-16 border-t border-gray-100">
    <div class="max-w-2xl mx-auto px-6 lg:px-8">
      <div class="prose space-y-6">
        <div><h2>1. Introduction</h2><p>Protomon Labs is committed to protecting your privacy. This policy explains how we collect, use, and safeguard your information when you visit our website.</p><p>We comply with the UK GDPR and the Data Protection Act 2018.</p></div>
        <div><h2>2. Data Controller</h2><p>Protomon Labs, Computational Genomics Lab, Cambridge, UK. Email: hello@protomonlabs.org</p></div>
        <div><h2>3. Information We Collect</h2><p>Name, email, and message content from our contact form. Anonymised analytics data (no persistent cookies).</p></div>
        <div><h2>4. Cookies</h2><p>We use privacy-preserving, cookie-free analytics. No advertising or marketing cookies are used.</p></div>
        <div><h2>5. How We Use Your Data</h2><p>To respond to enquiries, improve our website, understand usage patterns, and comply with legal obligations. We do not sell or share your data.</p></div>
        <div><h2>6. Data Retention</h2><p>Contact form submissions are retained for 12 months after correspondence concludes.</p></div>
        <div><h2>7. Your Rights</h2><p>Under UK/EU GDPR: right of access, rectification, erasure, restriction, portability, and objection. Contact hello@protomonlabs.org.</p></div>
        <div><h2>8. Contact</h2><p>hello@protomonlabs.org</p></div>
      </div>
    </div>
  </section>

<Fragment slot="footer"><Footer /></Fragment></Base>