---
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<Base title="About"><Fragment slot="header"><Header /></Fragment>

  <section class="relative pt-28 pb-16 overflow-hidden bg-subtle-grid" style="background:linear-gradient(135deg,#fafaf9 0%,#ffffff 30%,#ede9fe 100%)">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 relative">
      <div class="max-w-2xl"><p class="sl">About</p><h1 class="text-4xl sm:text-5xl font-heading font-bold text-stone-900 leading-tight mb-5">Infrastructure for the genome</h1><p class="text-lg md:text-xl text-stone-600 max-w-xl">Open-source infrastructure, maintained for the long term.</p></div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="space-y-5 text-stone-600 leading-relaxed">
          <p>Protomon builds open-source infrastructure that makes genomic discovery possible at scale. Genome browsers, standards implementations, and certification tooling, all maintained and production-ready. We believe the foundational layer of genomics should be a shared resource: open by default, built to last, and available to everyone.</p>
          <p>Everything is AGPL-licensed, keeping the work in the commons, with a dual-license path for organisations that need commercial use.</p>
        </div>
        <div class="aspect-[4/3] rounded-xl overflow-hidden bg-white flex items-center justify-center p-6">
          <img src="/building-blocks.svg" alt="" class="w-full h-full object-contain" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-stone-50 border-y border-stone-100 reveal">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="max-w-xl mb-10"><p class="sl">Values</p><h2 class="text-3xl font-heading font-bold text-stone-900">Our principles</h2></div>
      <div class="grid md:grid-cols-3 gap-5">
        <div class="card">
          <div class="icon-ring"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/></svg></div>
          <h3 class="font-heading font-semibold text-stone-900 mb-2">Open by default</h3>
          <p class="text-base text-stone-600 leading-relaxed">We build in the open because shared infrastructure is stronger. Every tool is publicly available and community contributions are welcome.</p>
        </div>
        <div class="card">
          <div class="icon-ring"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></div>
          <h3 class="font-heading font-semibold text-stone-900 mb-2">Built to last</h3>
          <p class="text-base text-stone-600 leading-relaxed">Professional engineering practices applied to tools the community depends on. Versioned, tested, documented, and maintained.</p>
        </div>
        <div class="card">
          <div class="icon-ring"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
          <h3 class="font-heading font-semibold text-stone-900 mb-2">Community first</h3>
          <p class="text-base text-stone-600 leading-relaxed">Good ideas come from anywhere. We contribute everything back upstream and build with, not for, our users.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 reveal">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="max-w-xl mx-auto">
        <div class="text-center">
          <div class="icon-ring w-14 h-14 rounded-xl mx-auto mb-4"><svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <h3 class="font-heading font-semibold text-stone-900 mb-1">Based in Oxford, UK</h3>
          <p class="text-base text-stone-600">We work with sequencing centers, biobanks, and tool developers around the world.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-20 overflow-hidden" style="background:linear-gradient(135deg,#5b21b6,#4c1d95,#3b0764)">
    <div class="absolute inset-0 bg-subtle-grid opacity-[0.08]" />
    <div class="max-w-6xl mx-auto px-6 lg:px-8 text-center relative">
      <div class="max-w-xl mx-auto">
        <h2 class="text-3xl font-heading font-bold text-white mb-3">Building the foundations of genomic discovery</h2>
        <p class="text-cobalt-200 leading-relaxed mb-8">We partner with sequencing centers, biobanks, and tool developers working at genomic scale.</p>
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-3 bg-white hover:bg-stone-50 text-stone-800 font-medium rounded-xl transition-all active:scale-[0.97]">Get in touch →</a>
      </div>
    </div>
  </section>

<Fragment slot="footer"><Footer /></Fragment></Base>