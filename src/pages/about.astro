---
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { icons } from "../data/icons";
---
<Base title="About"><Fragment slot="header"><Header /></Fragment>

  <section class="relative pt-28 pb-16 overflow-hidden bg-subtle-grid" style="background:linear-gradient(135deg,#fafaf9 0%,#ffffff 30%,#ede9fe 100%)">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 relative">
      <div class="max-w-2xl"><p class="sl">About</p><h1 class="text-4xl sm:text-5xl font-heading font-bold text-stone-900 leading-tight mb-5">Infrastructure for the genome</h1><p class="text-lg md:text-xl text-stone-600 max-w-xl">Open-source infrastructure, maintained for the long term.</p></div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="space-y-5 text-stone-600 leading-relaxed">
          <p>Protomon builds open-source infrastructure that makes genomic discovery possible at scale. Genome browsers, standards implementations, and certification tooling, all maintained and production-ready. We believe the foundational layer of genomics should be a shared resource: open by default, built to last, and available to everyone.</p>
          <p>Everything is AGPL-licensed, keeping the work in the commons, with a dual-license path for organisations that need commercial use.</p>
        </div>
        <div class="aspect-[4/3] flex items-center justify-center p-6">
          <img src="/building-blocks.svg" alt="" class="w-full h-full object-contain" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-50 border-y border-stone-100 reveal">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="max-w-xl mb-8"><p class="sl">Values</p><h2 class="text-3xl font-heading font-bold text-stone-900">Our principles</h2></div>
      <div class="grid md:grid-cols-3 gap-5">
        <div class="card">
          <div class="icon-ring" set:html={icons.beaker} />
          <h3 class="font-heading font-semibold text-stone-900 mb-2">Open by default</h3>
          <p class="text-[17px] text-stone-600 leading-relaxed">We build in the open because shared infrastructure is stronger. Every tool is publicly available and community contributions are welcome.</p>
        </div>
        <div class="card">
          <div class="icon-ring" set:html={icons.code} />
          <h3 class="font-heading font-semibold text-stone-900 mb-2">Built to last</h3>
          <p class="text-[17px] text-stone-600 leading-relaxed">Professional engineering practices applied to tools the community depends on. Versioned, tested, documented, and maintained.</p>
        </div>
        <div class="card">
          <div class="icon-ring" set:html={icons.users} />
          <h3 class="font-heading font-semibold text-stone-900 mb-2">Community first</h3>
          <p class="text-[17px] text-stone-600 leading-relaxed">Good ideas come from anywhere. We contribute everything back upstream and build with, not for, our users.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-16 overflow-hidden" style="background:linear-gradient(135deg,#5b21b6,#4c1d95,#3b0764)">
    <div class="absolute inset-0 bg-subtle-grid opacity-[0.08]" />
    <div class="max-w-6xl mx-auto px-6 lg:px-8 text-center relative">
      <div class="max-w-xl mx-auto">
        <h2 class="text-3xl font-heading font-bold text-white mb-3">Building the foundations of genomic discovery</h2>
        <p class="text-cobalt-200 leading-relaxed mb-8">Are you an academic lab, clinical group, or bioinformatic tool user working at the genomic scale? Get in touch with us.</p>
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-3 bg-white hover:bg-stone-50 text-stone-800 font-medium rounded-xl transition-all active:scale-[0.97]">Get in touch →</a>
      </div>
    </div>
  </section>

<Fragment slot="footer"><Footer /></Fragment></Base>