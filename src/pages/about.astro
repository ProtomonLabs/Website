---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="About">
  <Fragment slot="header">
    <Header />
  </Fragment>

  <section class="relative pt-32 pb-20 overflow-hidden" style="background: linear-gradient(180deg, #f0f9ff, #ffffff);">
    <div class="absolute inset-0 bg-dots-lg" />
    <div class="absolute bottom-0 right-0 w-48 h-48 opacity-[0.025] pointer-events-none select-none">
      <img src="/logo.svg" alt="" class="w-full h-full" aria-hidden="true" />
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
      <div class="max-w-3xl">
        <span class="section-label">About</span>
        <h1 class="text-5xl md:text-6xl font-heading font-bold text-slate-900 leading-tight mb-6">
          Advancing genomic<br />
          <span class="gradient-text">understanding</span>
        </h1>
        <p class="text-lg text-slate-600 leading-relaxed max-w-xl">
          Protomon Labs is a computational genomics research group focused on understanding the full spectrum of human genetic variation — from common polymorphisms to rare variants, from coding changes to non-coding regulation.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-start">
        <div class="md:col-span-1">
          <div class="relative">
            <div class="w-full aspect-[3/4] rounded-2xl flex items-center justify-center overflow-hidden border border-slate-200/40" style="background: linear-gradient(135deg, rgba(238,242,255,0.6), rgba(224,242,254,0.6));">
              <img src="/logo.svg" alt="Protomon Labs" class="w-32 h-32 opacity-40" />
            </div>
            <div class="absolute -bottom-3 -right-3 w-24 h-24 rounded-2xl -z-10" style="background: linear-gradient(135deg, rgba(129,140,248,0.2), rgba(56,189,248,0.2));" />
          </div>
        </div>
        <div class="md:col-span-2">
          <div class="space-y-5 text-slate-700 leading-relaxed">
            <p>
              We are a computational genomics research group dedicated to understanding how genetic variation influences human biology and disease. Our work bridges statistical genetics, population genomics, and functional genomics — developing methods and resources that accelerate the interpretation of genetic variation in both research and clinical contexts.
            </p>
            <p>
              Our primary focus is non-coding variant interpretation. While over 90% of disease-associated variants reside outside protein-coding regions, our ability to interpret their functional impact remains limited. We build computational approaches that integrate evolutionary constraint, epigenetic annotations, chromatin conformation, and molecular phenotypes to systematically characterize non-coding variation.
            </p>
            <p>
              Our approach is fundamentally interdisciplinary: we draw on statistics, machine learning, molecular biology, and population genetics to construct tools that empower the broader genomics community. We believe that rigorous, reproducible methods — shared openly — advance science faster.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-20 md:py-28 overflow-hidden" style="background: #f1f5f9;">
    <div class="absolute inset-0 bg-dots" />
    <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
      <div class="max-w-xl mb-16">
        <span class="section-label">Expertise</span>
        <h2 class="text-4xl md:text-5xl font-heading font-bold text-slate-900 leading-tight">
          Areas of<br class="hidden md:block" />
          <span class="gradient-text">depth</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {[
          {
            title: "Statistical Genomics",
            items: ["GWAS design and analysis", "Polygenic risk scores and prediction", "Fine-mapping causal variants", "Mendelian randomization", "High-dimensional omics integration"],
          },
          {
            title: "Population Genomics",
            items: ["Demographic inference", "Selection scans", "Ancestry deconvolution", "Cross-population variant catalogues", "Admixture mapping"],
          },
          {
            title: "Non-coding Variant Interpretation",
            items: ["Regulatory element annotation", "Enhancer-gene mapping", "Variant effect prediction (ML)", "Functional score integration", "Non-coding GWAS follow-up"],
          },
          {
            title: "Variant Analysis Pipeline",
            items: ["Whole-genome and exome analysis", "Rare variant association testing", "Structural variant discovery", "Clinical interpretation standards", "Benchmarking and reproducibility"],
          },
        ].map((area) => (
          <div class="card p-7 animate-in">
            <h3 class="text-lg font-heading font-semibold text-slate-900 mb-4">{area.title}</h3>
            <ul class="space-y-2">
              {area.items.map((item) => (
                <li class="flex items-center gap-3 text-sm text-slate-600">
                  <span class="w-1.5 h-1.5 rounded-full bg-cobalt-400/60 flex-shrink-0" />
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="max-w-xl mb-16">
        <span class="section-label">Values</span>
        <h2 class="text-4xl md:text-5xl font-heading font-bold text-slate-900 leading-tight">
          Lab<br class="hidden md:block" />
          <span class="gradient-text">philosophy</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="card p-8 text-center animate-in animate-in-delay-1">
          <div class="w-12 h-12 mx-auto rounded-xl flex items-center justify-center text-cobalt-600 mb-4" style="background: linear-gradient(135deg, rgba(238,242,255,0.8), rgba(224,242,254,0.8));">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="text-base font-heading font-semibold text-slate-900 mb-2">Open Science</h3>
          <p class="text-slate-600 text-sm leading-relaxed">All methods and software are open-source. Reproducibility and transparency are foundational to everything we build.</p>
        </div>
        <div class="card p-8 text-center animate-in animate-in-delay-2">
          <div class="w-12 h-12 mx-auto rounded-xl flex items-center justify-center text-cobalt-600 mb-4" style="background: linear-gradient(135deg, rgba(238,242,255,0.8), rgba(224,242,254,0.8));">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-base font-heading font-semibold text-slate-900 mb-2">Collaboration</h3>
          <p class="text-slate-600 text-sm leading-relaxed">We partner with clinical geneticists, methodologists, and bioinformaticians to ensure our work has real-world impact.</p>
        </div>
        <div class="card p-8 text-center animate-in animate-in-delay-3">
          <div class="w-12 h-12 mx-auto rounded-xl flex items-center justify-center text-cobalt-600 mb-4" style="background: linear-gradient(135deg, rgba(238,242,255,0.8), rgba(224,242,254,0.8));">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <path d="M2 12h20" />
              <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z" />
            </svg>
          </div>
          <h3 class="text-base font-heading font-semibold text-slate-900 mb-2">Diversity</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Committed to increasing diversity in genomic studies and developing methods that work equitably across all ancestral populations.</p>
        </div>
        <div class="card p-8 text-center animate-in animate-in-delay-4">
          <div class="w-12 h-12 mx-auto rounded-xl flex items-center justify-center text-cobalt-600 mb-4" style="background: linear-gradient(135deg, rgba(238,242,255,0.8), rgba(224,242,254,0.8));">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 14l9-5-9-5-9 5 9 5z" />
              <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
            </svg>
          </div>
          <h3 class="text-base font-heading font-semibold text-slate-900 mb-2">Mentorship</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Passionate about training the next generation of computational genomics researchers through hands-on, inclusive mentorship.</p>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>