---
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Form from "../components/ContactForm.tsx";
---
<Base title="Contact"><Fragment slot="header"><Header /></Fragment>

  <section class="pt-28 pb-16 bg-grid" style="background:linear-gradient(135deg,#eef2ff 0%,#ffffff 35%,#faf5ff 100%)">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl"><p class="sl">Contact</p><h1 class="text-4xl sm:text-5xl font-heading font-bold text-gray-900 leading-tight mb-5">Get in touch</h1><p class="text-lg text-gray-500 max-w-xl">Working on a large-scale sequencing project, building analysis tools, or developing population-scale genomics resources? Let's talk.</p></div>
    </div>
  </section>

  <section class="py-16 bg-gray-50 border-y border-gray-100">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="space-y-4">
          <div class="card"><h3 class="font-semibold text-gray-900 text-sm mb-1">Email</h3><p class="text-sm text-gray-500">hello@protomonlabs.org</p></div>
          <div class="card"><h3 class="font-semibold text-gray-900 text-sm mb-1">Location</h3><p class="text-sm text-gray-500">Computational Genomics Lab<br />Cambridge, UK</p></div>
          <div class="card"><h3 class="font-semibold text-gray-900 text-sm mb-1">Availability</h3><p class="text-sm text-gray-500">We aim to respond within 2–3 business days.</p></div>
        </div>
        <div class="md:col-span-2"><div class="card"><h2 class="text-lg font-heading font-semibold text-gray-900 mb-5">Send a message</h2><Form client:load /></div></div>
      </div>
    </div>
  </section>

<Fragment slot="footer"><Footer /></Fragment></Base>