---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.tsx";
---

<BaseLayout title="Contact">
  <Fragment slot="header"><Header /></Fragment>

  <section class="pt-32 pb-16" style="background: linear-gradient(180deg, #fafaf9, #ffffff);">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="max-w-3xl">
        <span class="section-label">Connect</span>
        <h1 class="text-5xl md:text-6xl font-heading font-bold text-stone-900 leading-tight mb-6">Get in <span class="text-cobalt-600">touch</span></h1>
        <p class="text-lg text-stone-600 max-w-xl">Working on a large-scale sequencing project, building analysis tools, or developing population-scale genomics resources? Let's talk.</p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-10">
        <div class="md:col-span-2 space-y-4">
          <div class="card p-5">
            <h3 class="font-semibold text-stone-900 text-sm mb-1">Email</h3>
            <p class="text-stone-500 text-sm">hello@protomonlabs.org</p>
          </div>
          <div class="card p-5">
            <h3 class="font-semibold text-stone-900 text-sm mb-1">Location</h3>
            <p class="text-stone-500 text-sm">Computational Genomics Lab<br />Cambridge, UK</p>
          </div>
          <div class="card p-5">
            <h3 class="font-semibold text-stone-900 text-sm mb-1">Availability</h3>
            <p class="text-stone-500 text-sm">We aim to respond within 2–3 business days.</p>
          </div>
        </div>
        <div class="md:col-span-3">
          <div class="card p-8">
            <h2 class="text-xl font-semibold text-stone-900 mb-5">Send a message</h2>
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>