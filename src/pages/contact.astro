---
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Form from "../components/ContactForm.tsx";
---
<Base title="Contact"><Fragment slot="header"><Header /></Fragment>

  <section class="relative pt-28 pb-16 overflow-hidden bg-subtle-grid" style="background:linear-gradient(135deg,#fafaf9 0%,#ffffff 30%,#ede9fe 100%)">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 relative">
      <div class="max-w-2xl"><p class="sl">Contact</p><h1 class="text-4xl sm:text-5xl font-heading font-bold text-stone-900 leading-tight mb-5">Get in touch</h1><p class="text-lg text-stone-600 max-w-xl">Interested in genomic infrastructure projects? We'd love to hear from you.</p></div>
    </div>
  </section>

  <section class="py-20 bg-stone-50 border-y border-stone-100 reveal">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="space-y-4">
          <div class="card"><h3 class="font-semibold text-stone-900 text-sm mb-1">Email</h3><p class="text-sm text-stone-600">hello@protomonlabs.org</p></div>
          <div class="card"><h3 class="font-semibold text-stone-900 text-sm mb-1">Location</h3><p class="text-sm text-stone-600">Computational Genomics Lab<br />Cambridge, UK</p></div>
          <div class="card"><h3 class="font-semibold text-stone-900 text-sm mb-1">Availability</h3><p class="text-sm text-stone-600">We aim to respond within 2–3 business days.</p></div>
        </div>
        <div class="md:col-span-2"><div class="card"><h2 class="text-lg font-heading font-semibold text-stone-900 mb-5">Send a message</h2><Form client:load /></div></div>
      </div>
    </div>
  </section>

<Fragment slot="footer"><Footer /></Fragment></Base>