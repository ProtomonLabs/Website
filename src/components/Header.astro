<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-9 h-9 rounded-lg bg-cobalt-600 flex items-center justify-center transition-transform duration-300 group-hover:scale-105"><img src="/logo.svg" alt="" class="w-7 h-7" style="filter:brightness(10)" /></div>
        <span class="text-lg font-heading font-semibold tracking-tight transition-colors duration-300"><span class="text-cobalt-600">Protomon</span> <span class="text-stone-800">Labs</span></span>
      </a>
      <nav class="hidden md:flex items-center gap-6">
        <a href="/" class="text-sm font-medium text-stone-600 hover:text-cobalt-600 transition-colors">Home</a>
        <a href="/about" class="text-sm font-medium text-stone-600 hover:text-cobalt-600 transition-colors">About</a>
        <a href="/projects" class="text-sm font-medium text-stone-600 hover:text-cobalt-600 transition-colors">Projects</a>
        <a href="/blog" class="text-sm font-medium text-stone-600 hover:text-cobalt-600 transition-colors">Blog</a>
        <a href="/contact" class="btn-p text-sm">Contact</a>
      </nav>
      <button id="mbtn" class="md:hidden p-2.5 rounded-xl bg-white/70 text-stone-600 hover:text-cobalt-600 transition-all" aria-label="Menu"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg></button>
    </div>
  </div>
  <div id="mmenu" class="hidden md:hidden bg-white/95 backdrop-blur-xl border-b border-stone-200/30 shadow-sm">
    <div class="px-6 lg:px-8 py-4 space-y-1">
      <a href="/" class="block px-4 py-3 text-stone-700 hover:text-cobalt-600 rounded-xl font-medium transition-colors">Home</a>
      <a href="/about" class="block px-4 py-3 text-stone-700 hover:text-cobalt-600 rounded-xl font-medium transition-colors">About</a>
      <a href="/projects" class="block px-4 py-3 text-stone-700 hover:text-cobalt-600 rounded-xl font-medium transition-colors">Projects</a>
      <a href="/blog" class="block px-4 py-3 text-stone-700 hover:text-cobalt-600 rounded-xl font-medium transition-colors">Blog</a>
      <a href="/contact" class="btn-p justify-center mt-2 w-full">Contact</a>
    </div>
  </div>
</header>
<script>
  const h = document.getElementById("site-header");
  if (h) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 60) { h.classList.add("bg-white/90","backdrop-blur-xl","shadow-sm","border-b","border-stone-200/20"); h.classList.remove("bg-transparent"); }
      else { h.classList.remove("bg-white/90","backdrop-blur-xl","shadow-sm","border-b","border-stone-200/20"); h.classList.add("bg-transparent"); }
    }, { passive: true });
  }
  document.getElementById("mbtn")?.addEventListener("click",()=>document.getElementById("mmenu")?.classList.toggle("hidden"));
</script>