      <button id="mbtn" class="md:hidden p-2.5 rounded-xl bg-white/70 text-stone-600 hover:text-cobalt-700 transition-colors" aria-label="Menu"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg></button>
    </div>
  </div>
  <div id="mmenu" class="hidden md:hidden bg-white/95 backdrop-blur-xl border-b border-stone-200 shadow-sm">
    <div class="px-6 lg:px-8 py-4 space-y-1">
      <a href="/" class="block px-4 py-3 text-stone-700 hover:text-cobalt-700 hover:bg-cobalt-50/50 rounded-xl font-medium transition-colors">Home</a>
      <a href="/about" class="block px-4 py-3 text-stone-700 hover:text-cobalt-700 hover:bg-cobalt-50/50 rounded-xl font-medium transition-colors">About</a>
      <a href="/principles" class="block px-4 py-3 text-stone-700 hover:text-cobalt-700 hover:bg-cobalt-50/50 rounded-xl font-medium transition-colors">Principles</a>
      <a href="/open-source" class="block px-4 py-3 text-stone-700 hover:text-cobalt-700 hover:bg-cobalt-50/50 rounded-xl font-medium transition-colors">Open Source</a>
      <a href="/contact" class="btn-p justify-center mt-2 w-full">Contact</a>
    </div>
  </div>
</header>
<script>
  const h = document.getElementById("site-header");
  if (h) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 60) { h.classList.add("bg-white/80","backdrop-blur-xl","border-b","border-stone-200","shadow-sm"); h.classList.remove("bg-transparent"); }
      else { h.classList.remove("bg-white/80","backdrop-blur-xl","border-b","border-stone-200","shadow-sm"); h.classList.add("bg-transparent"); }
    }, { passive: true });
  }
  document.getElementById("mbtn")?.addEventListener("click",()=>document.getElementById("mmenu")?.classList.toggle("hidden"));
  const p = window.location.pathname.replace(/\/+$/, "");
  document.querySelectorAll("#site-header nav a[href]:not(.btn-p)").forEach(a => { if (a.getAttribute("href").replace(/\/+$/, "") === p) a.classList.add("text-cobalt-700","font-semibold"); else a.classList.add("text-stone-600"); });
</script>