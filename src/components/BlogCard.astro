---
export interface BlogPost {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
}

const { posts }: { posts: BlogPost[] } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
  {posts.map((post) => (
    <a
      href={`/blog/${post.slug}`}
      class="card p-7 group block animate-in"
    >
      <div class="flex flex-wrap gap-2 mb-4">
        {post.tags.map((tag) => (
          <span class="tag text-[11px]">{tag}</span>
        ))}
      </div>
      <h3 class="text-lg font-heading font-semibold text-ocean-900 group-hover:text-cobalt-600 transition-colors mb-3 leading-snug">
        {post.title}
      </h3>
      <p class="text-ocean-600/80 text-sm leading-relaxed mb-5 line-clamp-2">
        {post.description}
      </p>
      <div class="flex items-center justify-between">
        <time class="text-ocean-400 text-xs tracking-wide">
          {post.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        <span class="text-cobalt-500 text-xs font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
          Read
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </div>
    </a>
  ))}
</div>