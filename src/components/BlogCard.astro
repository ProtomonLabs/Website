---
export interface P { title: string; description: string; pubDate: Date; tags: string[]; slug: string; }
const { posts } = Astro.props;
---
<div class="grid md:grid-cols-2 gap-5">
  {posts.map((p) => (
    <a href={`/blog/${p.slug}`} class="card block group">
      <div class="flex flex-wrap gap-1.5 mb-3">{p.tags.map((t) => (<span class="tag">{t}</span>))}</div>
      <h3 class="font-heading font-semibold text-gray-900 mb-2 leading-snug group-hover:text-cobalt-600">{p.title}</h3>
      <p class="text-sm text-gray-500 leading-relaxed mb-4">{p.description}</p>
      <div class="flex items-center justify-between">
        <span class="text-xs text-gray-400">{p.pubDate.toLocaleDateString("en-US",{month:"long",day:"numeric",year:"numeric"})}</span>
        <span class="text-xs text-cobalt-600 font-medium">Read</span>
      </div>
    </a>
  ))}
</div>