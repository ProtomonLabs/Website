---
const areas = [
  { title: "Genomic Data Platforms", description: "Scalable infrastructure for managing, querying, and analyzing genome-scale data across populations." },
  { title: "Variant Annotation Infrastructure", description: "Standardized pipelines and community resources for reproducible interpretation of genetic variation at scale." },
  { title: "Open Science Toolchains", description: "Computational frameworks and open datasets that empower the global genomics community." },
];
---
<section class="py-24 bg-stone-50 reveal">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="max-w-xl mb-12">
      <p class="sl mb-0">Infrastructure</p>
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-stone-900">What we build</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      <div class="card reveal reveal-d1">
        <div class="w-10 h-10 rounded-lg bg-cobalt-100 flex items-center justify-center text-cobalt-700 mb-4">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" />
            <rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" />
          </svg>
        </div>
        <h3 class="text-lg font-heading font-semibold text-stone-900 mb-2">{areas[0].title}</h3>
        <p class="text-sm text-stone-600 leading-relaxed">{areas[0].description}</p>
      </div>
      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-cobalt-100 flex items-center justify-center text-cobalt-700 mb-4">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" />
          </svg>
        </div>
        <h3 class="text-lg font-heading font-semibold text-stone-900 mb-2">{areas[1].title}</h3>
        <p class="text-sm text-stone-600 leading-relaxed">{areas[1].description}</p>
      </div>
      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-cobalt-100 flex items-center justify-center text-cobalt-700 mb-4">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="18" cy="5" r="3" /><circle cx="6" cy="12" r="3" /><circle cx="18" cy="19" r="3" />
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" /><line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
          </svg>
        </div>
        <h3 class="text-lg font-heading font-semibold text-stone-900 mb-2">{areas[2].title}</h3>
        <p class="text-sm text-stone-600 leading-relaxed">{areas[2].description}</p>
      </div>
    </div>
  </div>
</section>