---
import { icons } from "../data/icons";
const areas = [
  { title: "Beautiful genome browsers", description: "Reference implementations for visualizing structural variants and comparative genomics data at scale.", icon: "browser" },
  { title: "Standards in practice", description: "Reference implementations, SDKs, and certification infrastructure for community standards.", icon: "layers" },
  { title: "Sustainable infrastructure", description: "Engineer-built and maintained through support contracts, providing long-term stability for the tools the community depends on.", icon: "shield" },
];
---
<section class="py-16 bg-stone-50">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="max-w-xl mb-8">
      <p class="sl mb-0">Infrastructure</p>
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-stone-900">What we build</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      {areas.map((a) => (
        <div class="card">
          <div class="icon-ring" set:html={icons[a.icon]} />
          <h3 class="text-lg font-heading font-semibold text-stone-900 mb-2">{a.title}</h3>
          <p class="text-base text-stone-600 leading-relaxed">{a.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>