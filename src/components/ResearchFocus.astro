---
const areas = [
  { title: "Genomic Data Platforms", description: "Scalable infrastructure for managing, querying, and analyzing genome-scale data across populations — from variant call standardization to cloud-native analysis pipelines." },
  { title: "Variant Annotation Infrastructure", description: "Standardized pipelines, benchmarking frameworks, and community reference resources for consistent, reproducible interpretation of genetic variation at any scale." },
  { title: "Open Science Toolchains", description: "Computational frameworks, open datasets, and collaborative platforms that empower the global genomics community to build on shared foundations." },
];
---

<section class="py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="max-w-xl mb-12">
      <span class="section-label">Infrastructure</span>
      <h2 class="text-4xl font-heading font-bold text-stone-900 leading-tight">What we <span class="gradient-text">build</span></h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {areas.map((a) => (
        <div class="card p-8">
          <h3 class="text-xl font-semibold text-stone-900 mb-3">{a.title}</h3>
          <p class="text-stone-600 text-sm leading-relaxed">{a.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>