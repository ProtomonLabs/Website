---
const areas = [
  { title: "Beautiful genome browsers", description: "We partner with sequencing centers, biobanks, and tool developers working at genomic scale.", icon: "browser" },
  { title: "Standards in practice", description: "Reference implementations, SDKs, and certification infrastructure for community standards.", icon: "standards" },
  { title: "Sustainable infrastructure", description: "Engineer-built and maintained through support contracts, providing long-term stability for the tools the community depends on.", icon: "shield" },
];
const icons = {
  browser: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8" cy="8" r="1.5"/><path d="M3 12h18"/><path d="M12 3v18"/></svg>',
  standards: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>',
  shield: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
};
---
<section class="py-20 bg-stone-50">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="max-w-xl mb-12">
      <p class="sl mb-0">Infrastructure</p>
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-stone-900">What we build</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      {areas.map((a) => (
        <div class="card">
          <div class="icon-ring" set:html={icons[a.icon]} />
          <h3 class="text-lg font-heading font-semibold text-stone-900 mb-2">{a.title}</h3>
          <p class="text-sm text-stone-600 leading-relaxed">{a.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>