---
export interface Project {
  title: string;
  description: string;
  tags: string[];
  status: "active" | "completed" | "in-review";
}

const { projects, maxDisplay }: { projects: Project[]; maxDisplay?: number } = Astro.props;
const display = maxDisplay ? projects.slice(0, maxDisplay) : projects;

const statusColors: Record<string, string> = {
  active: "bg-cobalt-50/70 text-cobalt-700",
  completed: "bg-stone-100 text-stone-600",
  "in-review": "bg-amber-50/70 text-amber-700",
};
const statusLabels: Record<string, string> = { active: "Active", completed: "Completed", "in-review": "In Review" };
const statusDots: Record<string, string> = { active: "bg-cobalt-500", completed: "bg-stone-400", "in-review": "bg-amber-500" };
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
  {display.map((project) => (
    <a href="/projects" class="card p-7 group block">
      <div class="flex items-start justify-between gap-4 mb-3">
        <h3 class="text-lg font-semibold text-stone-900 group-hover:text-cobalt-600 transition-colors leading-snug">{project.title}</h3>
        <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-medium whitespace-nowrap ${statusColors[project.status]}`}>
          <span class={`w-1.5 h-1.5 rounded-full mr-1.5 ${statusDots[project.status]}`} />
          {statusLabels[project.status]}
        </span>
      </div>
      <p class="text-stone-600 text-sm leading-relaxed mb-4 line-clamp-3">{project.description}</p>
      <div class="flex flex-wrap gap-2">
        {project.tags.map((tag) => (<span class="tag text-[11px]">{tag}</span>))}
      </div>
    </a>
  ))}
</div>